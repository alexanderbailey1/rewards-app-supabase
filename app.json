{
  "expo": {
    "scheme": "rewardsapp",
    "name": "rewards-app-supabase",
    "slug": "rewards-app-supabase",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/havenIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/havenIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.haven.rewardsapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9d7afdd9-0a03-42b4-b693-65da45983dec"
      }
    },
    "owner": "abaybayapps"
  }
}
